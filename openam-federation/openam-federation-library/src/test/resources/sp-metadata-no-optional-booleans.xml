<!--
  SP metadata that deliberately OMITS every optional boolean attribute
  (WantAssertionsSigned, AuthnRequestsSigned on SPSSODescriptor and isDefault on
  the AssertionConsumerService entries). Under JAXB 3 these map to nullable
  Boolean getters that return null when the attribute is absent, so this fixture
  guards the migration against auto-unboxing NullPointerExceptions on core SSO
  paths that previously saw a primitive false.
-->
<EntityDescriptor
        xmlns="urn:oasis:names:tc:SAML:2.0:metadata"
        entityID="https://sp.example.com/no-optional-booleans">
    <SPSSODescriptor
            protocolSupportEnumeration="urn:oasis:names:tc:SAML:2.0:protocol">
        <SingleLogoutService
                Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-Redirect"
                Location="https://sp.example.com/SPSloRedirect/metaAlias/sp"/>
        <NameIDFormat>
            urn:oasis:names:tc:SAML:2.0:nameid-format:persistent
        </NameIDFormat>
        <AssertionConsumerService
                Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-POST"
                Location="https://sp.example.com/AssertionConsumer/metaAlias/sp"
                index="0"/>
        <AssertionConsumerService
                Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-Artifact"
                Location="https://sp.example.com/Artifact/metaAlias/sp"
                index="1"/>
    </SPSSODescriptor>
</EntityDescriptor>
